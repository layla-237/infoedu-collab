<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Specializări - Eliceu</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #f7f2fb;
      color: #17121f;
    }

    header {
      width: 100%;
      height: 72px;
      background: #9661b8;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 42px;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .menu {
      font-size: 32px;
      color: #ffffff;
      font-weight: 900;
      background: transparent;
      border: 0;
      cursor: pointer;
    }

    .logo {
      font-size: 34px;
      font-weight: 900;
      color: #ffe34d;
      letter-spacing: -1px;
    }

    nav {
      display: flex;
      gap: 38px;
    }

    nav a {
      color: #ffffff;
      text-decoration: none;
      font-size: 13px;
      font-weight: 900;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: -320px;
      width: 320px;
      height: 100vh;
      background: linear-gradient(180deg, #8c63b3 0%, #6f4796 100%);
      z-index: 2000;
      padding: 110px 40px;
      display: flex;
      flex-direction: column;
      gap: 28px;
      transition: 0.35s;
      box-shadow: 6px 0 30px rgba(0,0,0,0.18);
    }

    .sidebar.active {
      left: 0;
    }

    .sidebar a {
      text-decoration: none;
      color: #ffffff;
      font-size: 22px;
      font-weight: 900;
      transition: 0.2s;
    }

    .sidebar a:hover {
      color: #ffe34d;
      transform: translateX(8px);
    }

    .close-btn {
      position: absolute;
      top: 28px;
      right: 28px;
      background: transparent;
      border: none;
      font-size: 34px;
      cursor: pointer;
      color: #ffffff;
      font-weight: 900;
    }

    main {
      padding: 105px 70px 80px;
    }

    .hero-specializare {
      min-height: 430px;
      border-radius: 28px;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(25, 10, 42, 0.95), rgba(80, 23, 126, 0.65)),
        url("profil-real.jpg");
      background-size: cover;
      background-position: center;
      color: white;
      padding: 70px;
      display: flex;
      align-items: center;
    }

    /*.hero-text {
      max-width: 520px;
    }*/

    .breadcrumb {
      font-size: 14px;
      font-weight: 700;
      opacity: 0.8;
      margin-bottom: 65px;
    }


    .section-title {
      margin-top: 42px;
      margin-bottom: 24px;
      font-size: 28px;
      font-weight: 900;
      position: relative;
    }

    .section-title::after {
      content: "";
      display: block;
      width: 44px;
      height: 4px;
      background: #9661b8;
      border-radius: 999px;
      margin-top: 10px;
    }

    .subjects {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 26px;
      margin-bottom: 34px;
    }

    .subject-card {
      background: white;
      border-radius: 16px;
      padding: 30px 24px;
      min-height: 220px;
      box-shadow: 0 10px 28px rgba(0,0,0,0.08);
    }

    .icon {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: linear-gradient(135deg, #b765e4, #7c3fc0);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 27px;
      color: white;
      margin-bottom: 22px;
    }

    .subject-card h3 {
      font-size: 20px;
      font-weight: 900;
      margin-bottom: 12px;
    }

    .subject-card p {
      font-size: 15px;
      line-height: 1.55;
      font-weight: 500;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1.25fr;
      background: white;
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      overflow: hidden;
      margin-top: 30px;
    }

    .fit-box,
    .careers-box {
      padding: 36px;
    }

    .fit-box {
      border-right: 1px solid #eadff1;
    }

    .fit-box h2,
    .careers-box h2 {
      font-size: 26px;
      font-weight: 900;
      margin-bottom: 28px;
      position: relative;
    }

    .fit-box h2::after,
    .careers-box h2::after {
      content: "";
      display: block;
      width: 42px;
      height: 4px;
      background: #9661b8;
      border-radius: 999px;
      margin-top: 10px;
    }

    .fit-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 18px;
      margin-bottom: 28px;
    }

    .fit-list li {
      font-size: 16px;
      font-weight: 600;
      line-height: 1.4;
    }

    .fit-list li::before {
      content: "✓";
      background: #a64ed0;
      color: white;
      font-weight: 900;
      border-radius: 50%;
      padding: 2px 6px;
      margin-right: 12px;
    }

    .note {
      background: #f4e8fb;
      padding: 18px;
      border-radius: 12px;
      color: #6f3496;
      font-size: 15px;
      font-weight: 700;
      line-height: 1.5;
    }

    .careers {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      justify-content: center;
    }

    .career-card {
  background: #f8effc;
  border-radius: 14px;
  padding: 24px 12px;
  text-align: center;
  font-weight: 900;
  display: flex;
  align-items: center;      
  justify-content: center;  
  min-height: 90px;       
}

    .career-icon {
      font-size: 34px;
      margin-bottom: 12px;
    }

    .quiz-banner {
      margin-top: 48px;
      background: linear-gradient(90deg, #7430a6, #a44dd4);
      border-radius: 20px;
      padding: 38px 48px;
      color: white;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
      overflow: hidden;
    }

    .quiz-banner h2 {
      font-size: 24px;
      font-weight: 900;
      margin-bottom: 10px;
    }

    .quiz-banner p {
      font-size: 15px;
      font-weight: 500;
    }

    .quiz-banner a {
      background: white;
      color: #7c3fc0;
      text-decoration: none;
      padding: 18px 28px;
      border-radius: 12px;
      font-weight: 900;
      white-space: nowrap;
    }

    footer {
      background: #786286;
      padding: 80px 90px 90px;
      color: white;
    }

    .footer-logo {
      font-size: 24px;
      font-weight: 900;
      color: #ffe34d;
      margin-bottom: 22px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 80px;
    }

    footer h3 {
      font-size: 17px;
      font-weight: 900;
      margin-bottom: 14px;
    }

    footer a {
      display: block;
      color: white;
      text-decoration: none;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    @media (max-width: 900px) {
      main {
        padding: 95px 24px 60px;
      }

      .hero-specializare {
        padding: 42px 28px;
      }

      .hero-specializare h1 {
        font-size: 42px;
      }

      .subjects {
        grid-template-columns: 1fr;
      }

      .info-grid {
        grid-template-columns: 1fr;
      }

      .fit-box {
        border-right: none;
        border-bottom: 1px solid #eadff1;
      }

      .careers {
        grid-template-columns: 1fr;
      }

      .quiz-banner {
        flex-direction: column;
        align-items: flex-start;
      }

      .footer-grid {
        grid-template-columns: 1fr;
        gap: 24px;
      }
    }
  </style>
</head>

<body>

  <header>
    <div class="logo-area">
      <button class="menu" id="menuBtn">☰</button>
      <div class="logo">Ǝliceu</div>
    </div>

    <nav>
      <a href="index.html">Acasă</a>
      <a href="licee.html">Toate liceele</a>
      <a href="profil.html">Profiluri</a>
      <a href="test.html">Test de orientare</a>
    </nav>
  </header>

  <div class="sidebar" id="sidebar">
    <button class="close-btn" id="closeBtn">✕</button>
    <a href="index.html">Acasă</a>
    <a href="profil.html">Profil</a>
    <a href="licee.html">Toate liceele</a>
    <a href="specializari.html">Specializări</a>
    <a href="test.html">Test de orientare</a>
    <a href="evenimente.html">Evenimente și noutăți</a>
    <a href="despre.html">Despre noi</a>
    <a href="contact.html">Contact</a>
  </div>

  <main>

    <section class="hero-specializare">
